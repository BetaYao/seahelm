# Copy to .env and fill in before `docker compose up`.

# Public hostname (must already point at this host for Caddy / Let's Encrypt)
DOMAIN=gw.seahelm.dev

# Shared secret for Watch (and any HTTP client) → gateway
# Authorization: Bearer <WATCH_API_KEY>
WATCH_API_KEY=change-me-to-a-long-random-string

# EMQX Dashboard (http://127.0.0.1:18083 on the host)
EMQX_DASHBOARD_PASSWORD=change-me-dashboard

# MQTT user the gateway uses on the internal docker network.
# Create this user in EMQX Dashboard → Authentication after first boot
# (or leave blank only while testing with anonymous allowed).
MQTT_USERNAME=seahelm
MQTT_PASSWORD=change-me-mqtt
