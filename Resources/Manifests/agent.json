{
  "id": "agent",
  "version": "2026.07.22.1",
  "min_engine_version": 1,
  "aliases": [],
  "default_status": "idle",
  "message_skip_patterns": [
    "shift+tab",
    "accept edits",
    "to interrupt",
    "ctrl+c to stop"
  ],
  "authority": "screen_only",
  "rules": [
    {
      "id": "osc_title_working",
      "state": "running",
      "priority": 1100,
      "region": "osc_title",
      "regex": [
        "^[\\x{2800}-\\x{28FF}] "
      ],
      "visible_working": true
    },
    {
      "id": "working_interrupt",
      "state": "running",
      "priority": 400,
      "region": "bottom_lines:10",
      "any": [
        {
          "contains": [
            "ctrl+c to stop"
          ]
        },
        {
          "contains": [
            "to interrupt"
          ]
        },
        {
          "contains": [
            "esc to abort"
          ]
        }
      ],
      "visible_working": true
    },
    {
      "id": "working_status_line",
      "state": "running",
      "priority": 390,
      "region": "bottom_lines:12",
      "any": [
        {
          "line_regex": [
            "(?i)^\\s*working…?\\s*$"
          ]
        },
        {
          "line_regex": [
            "(?i)^\\s*thinking\\s*$"
          ]
        },
        {
          "line_regex": [
            "(?i)^\\s*generating\\b"
          ]
        },
        {
          "line_regex": [
            "(?i)\\d+(\\.\\d+)?k tokens"
          ]
        }
      ],
      "visible_working": true
    },
    {
      "id": "error_line",
      "state": "error",
      "priority": 700,
      "region": "bottom_lines:10",
      "contains": [
        "error"
      ]
    },
    {
      "id": "waiting_prompt",
      "state": "waiting",
      "priority": 300,
      "region": "bottom_lines:6",
      "any": [
        {
          "contains": [
            "?"
          ]
        },
        {
          "line_regex": [
            "^\\s*>\\s"
          ]
        }
      ],
      "visible_blocker": true
    }
  ]
}
