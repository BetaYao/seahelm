{
  "id": "cline",
  "version": "2026.07.08.1",
  "min_engine_version": 1,
  "aliases": [],
  "default_status": "idle",
  "message_skip_patterns": ["shift+tab", "accept edits", "to interrupt"],
  "process": {
    "exec_names": ["cline"],
    "argv_contains": ["cline"],
    "generic_runtimes": ["node","bun","deno"],
    "env_hint": "SEAHELM_AGENT"
  },
  "authority": "screen_only",
  "rules": [
    {
      "id": "working_interrupt",
      "state": "running",
      "priority": 400,
      "region": "bottom_lines:10",
      "any": [{ "contains": ["to interrupt"] }, { "contains": ["(thinking)"] }, { "contains": ["esc to interrupt"] }],
      "visible_working": true
    },
    {
      "id": "error_line",
      "state": "error",
      "priority": 700,
      "region": "bottom_lines:10",
      "any": [{ "contains": ["error:"] }, { "line_regex": ["(?i)^\\s*error\\b"] }]
    },
    {
      "id": "waiting_prompt",
      "state": "waiting",
      "priority": 850,
      "region": "bottom_lines:8",
      "any": [{ "contains": ["(y/n)"] }, { "contains": ["(yes/no)"] }, { "contains": ["do you want to proceed?"] }, { "contains": ["? "] }],
      "visible_blocker": true
    }
  ]
}
